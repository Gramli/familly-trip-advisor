{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Backend API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build: backend",
            "program": "${workspaceFolder}/backend/bin/Debug/net10.0/familly-trip-advisor.dll",
            "args": [],
            "cwd": "${workspaceFolder}/backend",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}
